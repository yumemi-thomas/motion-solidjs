{
  "name": "motion-solidjs",
  "version": "0.3.0",
  "description": "Motion-compatible animation primitives for SolidJS",
  "keywords": [
    "motion",
    "solid"
  ],
  "homepage": "https://github.com/yumemi-thomas/motion-solidjs/tree/main/packages/solid",
  "bugs": {
    "url": "https://github.com/yumemi-thomas/motion-solidjs/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yumemi-thomas/motion-solidjs.git",
    "directory": "packages/solid"
  },
  "files": [
    "./LICENSE",
    "./README.md",
    "./dist/v1"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/v1/index.mjs",
  "module": "./dist/v1/index.mjs",
  "types": "./dist/v1/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/v1/index.d.mts",
      "import": "./dist/v1/index.mjs"
    },
    "./v1": {
      "types": "./dist/v1/index.d.mts",
      "import": "./dist/v1/index.mjs"
    }
  },
  "scripts": {
    "build": "vp pack src/index.ts --dts --format esm --out-dir dist/v1 --unbundle --clean --from-vite",
    "dev": "vp pack src/index.ts --dts --format esm --out-dir dist/v1 --unbundle --watch --from-vite",
    "prepublishOnly": "pnpm build",
    "test:types": "pnpm build && tsgo --noEmit -p type-tests/tsconfig.json",
    "test": "vitest run",
    "test:client": "vitest run --project=client",
    "test:browser": "vitest run --project=browser",
    "test:ssr": "vitest run --project=ssr"
  },
  "dependencies": {
    "@solid-primitives/refs": "^1.1.3",
    "@solid-primitives/transition-group": "^1.1.2"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@vitest/browser-playwright": "^4.1.7",
    "jsdom": "^29.1.1",
    "motion": "^12.40.0",
    "motion-dom": "^12.40.0",
    "motion-utils": "^12.39.0",
    "playwright": "^1.60.0",
    "solid-js": "^1.9.13",
    "vite-plugin-solid": "^2.11.12"
  },
  "peerDependencies": {
    "motion": "^12.0.0",
    "motion-dom": "^12.0.0",
    "motion-utils": "^12.0.0",
    "solid-js": ">=1.8.0"
  }
}
